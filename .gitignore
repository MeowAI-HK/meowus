# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist-electron/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# codex temporary files
.codex-*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local app runtime data
/web-data

# playwright runtime artifacts
/.playwright-cli/
/.playwright-mcp/
/playwright-report/
/test-results/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# codex auto-generated files
.codex-*
