{
  "name": "meowus",
  "version": "0.1.0",
  "description": "Meowus by SMEPost — open-source social media agent for local-first multi-account workflows, scheduled posting, and agent-driven browser tasks.",
  "license": "MIT",
  "author": "MeowAI-HK",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MeowAI-HK/meowus.git"
  },
  "homepage": "https://github.com/MeowAI-HK/meowus#readme",
  "bugs": {
    "url": "https://github.com/MeowAI-HK/meowus/issues"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "pnpm@10.26.1",
  "keywords": [
    "ai-social-media-automation",
    "social-media-agent",
    "scheduled-posting",
    "browser-automation",
    "electron",
    "nextjs",
    "smepost"
  ],
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "pnpm icons:generate && next build",
    "icons:generate": "tsx scripts/generate-icons.ts",
    "electron:pack": "pnpm build && tsx scripts/prepare-electron-bundle.ts && electron-builder --dir",
    "electron:build": "pnpm build && tsx scripts/prepare-electron-bundle.ts && electron-builder",
    "electron:build:win": "pnpm build && tsx scripts/prepare-electron-bundle.ts && electron-builder --win dir",
    "electron:build:mac": "pnpm build && tsx scripts/prepare-electron-bundle.ts && electron-builder --mac dmg --arm64",
    "electron:build:store": "pnpm build && tsx scripts/prepare-electron-bundle.ts && tsx scripts/build-store-package.ts",
    "start": "next start --hostname 127.0.0.1",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "electron:dry-run": "tsx scripts/electron-dry-run.ts",
    "worker": "tsx src/worker/worker.ts",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@heroui/react": "^3.0.3",
    "@langchain/core": "^1.1.48",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/openai": "^1.4.7",
    "@libsql/client": "^0.17.2",
    "cheerio": "^1.2.0",
    "cloakbrowser": "^0.3.30",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.7.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "nanoid": "^5.1.9",
    "next": "16.2.4",
    "playwright": "^1.60.0",
    "playwright-core": "^1.59.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^4.11.1",
    "swr": "^2.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
