# Local-only Meowus settings.
# Copy to .env.local and fill only the providers you use.

SOCIAL_AUTO_POST_DB_URL=file:./web-data/social-auto-post.db
SOCIAL_AUTO_POST_LOCAL_TOKEN=change-this-local-token

# AI keys stay server-side. Multiple keys can be separated by commas or newlines.
GEMINI_API_KEYS=
GEMINI_MODEL=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

GROQ_API_KEYS=
GROQ_MODEL=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Optional OpenAI-compatible text and image endpoint.
OPENAI_API_KEYS=
OPENAI_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=
OPENAI_IMAGE_SIZE=
GEMINI_IMAGE_MODEL=

# Optional OpenRouter text endpoint.
OPENROUTER_API_KEYS=
OPENROUTER_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# SMEPost cloud backend (default: production).
SMEPOST_API_BASE_URL=https://smepost.io
